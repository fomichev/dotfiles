#!/bin/bash

export ET_NO_TELEMETRY=yes

SESSION=${1:-$(tmux display-message -p '#S')}

set_current_command() {
	local host=$1; shift
	tmux set-option -t $SESSION @host ":$host"
	tmux set-option -t $SESSION default-command "$*"
	tmux show-option -t $SESSION default-command
}

shortname() {
	echo "$*" | cut -d. -f1
}

case "$SESSION" in
"mini-arch")
	set_current_command mini-arch et 76.102.12.149
	;;
"mooncake")
	#HOST=devgpu003.lco1.facebook.com
	HOST=devvm17672.vll0.facebook.com
	NAME=$(shortname $HOST)
	set_current_command $NAME x2ssh -et $HOST
	;;
"tcp_devmem")
	HOST=devvm7509.cco0.facebook.com
	NAME=$(shortname $HOST)
	set_current_command $NAME x2ssh -et $HOST
	;;
esac
