#!/bin/bash

MYDIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}" )" &>/dev/null && pwd)
source $MYDIR/../host_lib.sh

OPTS=--effort=max

DIR=$HOME/src/review-prompts

if [[ ! -d "$DIR" ]]; then
	pushd $(dirname $DIR)
	git clone https://github.com/masoncl/review-prompts
	popd
else
	pushd $DIR
	git pull
	popd
fi

UNPUSHED=$(git log --format='%h' @{u}..HEAD 2>/dev/null)
PROMPT="review all unpushed commits: $UNPUSHED"

if [[ ! -z "$*" ]]; then
	PROMPT="$@"
fi

claude $OPTS "Using the prompt $DIR/kernel/review-core.md and the review prompt directory $DIR/kernel, $PROMPT"
