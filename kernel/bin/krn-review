#!/usr/bin/python3

# WORKFLOW:
# cat ~/Mail/all/cur/<hash>:2,S | krn-review start [--tmux]
# cd ~/review/<dir>
# edit reply/ files to add inline comments
# manual replies or krn-review feedback
# krn-review reply [--dry]

import argparse
import email
import email.policy
import filecmp
import re
import os
import os.path
import subprocess
import shutil
import sys

DIR_PROMPTS = '/home/sdf/src/review-prompts'
DIR_LINUX = '/home/sdf/src/linux'
DIR_REVIEW = '/home/sdf/review'
DIR_MAIL = '/home/sdf/Mail'
ME = 'Stanislav Fomichev'
HARNESSES = ['claude --effort=max', 'codex', 'gemini']

def sanitize_subj(subj):
    # Count and strip Re: prefixes
    re_count = 0
    s = subj
    while s.lower().startswith('re: ') or s.lower().startswith('re:'):
        re_count += 1
        s = re.sub(r'^[Rr][Ee]:\s*', '', s)

    cols = s.replace(": ", " ").split("]")

    name = cols[1].strip('. ')

    match = re.search(r"(\d+)/\d+", cols[0])
    num = match.group(1) if match else '0'
    prefix = f"{int(num):02d}"
    if re_count > 0:
        prefix += f"_RE{re_count}"

    name = re.sub('\\[', '', name)
    name = re.sub('\\]', '', name)
    name = re.sub('[^0-9a-zA-Z]+', '_', name)
    return f"{prefix}_{name}"

def create_reply(msg):
    policy = email.policy.EmailPolicy(utf8=True)
    rsp = email.message.EmailMessage(policy=policy)
    rsp.add_header('To', msg['From'])
    if msg['Cc']:
        rsp.add_header('Cc', msg['Cc'])
    rsp.add_header('In-Reply-To', msg['Message-Id'])

    subj = msg['Subject']

    if not subj.startswith('Re: '):
        subj = 'Re: ' + subj

    rsp.add_header('Subject', subj)
    rsp.add_header('Content-Type', msg.get('Content-Type', 'text/plain'))

    body = msg.get_body(preferencelist=['plain']).get_payload()
    lines = [ '> ' + x for x in body.splitlines() ]
    body = "\n".join(lines)
    rsp.set_payload(body)

    return rsp.as_string(policy=policy)

def create_reply_templates(review_dir, my_from):
    policy = email.policy.EmailPolicy(utf8=True)
    reply_dir = os.path.join(review_dir, 'reply')
    ref_dir = os.path.join(review_dir, 'ref')
    os.makedirs(reply_dir, exist_ok=True)
    os.makedirs(ref_dir, exist_ok=True)

    # Read root to determine if I'm the author
    root_path = os.path.join(review_dir, '00_root')
    with open(root_path) as f:
        root_msg = email.message_from_file(f, policy=policy)
    author = root_msg['From']
    i_am_author = my_from in author

    # Parse all messages in the review dir
    messages = {}  # name -> parsed msg
    for name in sorted(os.listdir(review_dir)):
        path = os.path.join(review_dir, name)
        if not os.path.isfile(path):
            continue
        try:
            with open(path) as f:
                msg = email.message_from_file(f, policy=policy)
            messages[name] = msg
        except Exception:
            continue

    # Single-patch mode: no cover letter, root is the only patch from the author
    has_other_patches = any(
        name != '00_root' and my_from in (msg.get('From') or '')
        for name, msg in messages.items()
    ) if i_am_author else any(
        name != '00_root' and my_from not in (msg.get('From') or '')
        for name, msg in messages.items()
    )
    skip_root = has_other_patches

    if i_am_author:
        # Find leaf messages: those whose Message-Id is not in any In-Reply-To
        replied_to = set()
        for msg in messages.values():
            irt = msg.get('In-Reply-To', '')
            if irt:
                replied_to.add(irt.strip())

        for name, msg in messages.items():
            if name == '00_root' and skip_root:
                continue
            # Only reply to leaf messages not from me
            if my_from in (msg.get('From') or ''):
                continue
            msgid = msg.get('Message-Id', '').strip()
            if msgid in replied_to:
                continue
            contents = create_reply(msg)
            print(f'reply template: {name}')
            with open(os.path.join(reply_dir, name), 'w') as f:
                f.write(contents)
            with open(os.path.join(ref_dir, name), 'w') as f:
                f.write(contents)
    else:
        # I'm the reviewer: create replies for all messages
        for name, msg in messages.items():
            if name == '00_root' and skip_root:
                continue
            contents = create_reply(msg)
            print(f'reply template: {name}')
            with open(os.path.join(reply_dir, name), 'w') as f:
                f.write(contents)
            with open(os.path.join(ref_dir, name), 'w') as f:
                f.write(contents)

def get_msg(args):
    policy = email.policy.EmailPolicy(utf8=True)

    if args.message == '-':
        return email.message_from_file(sys.stdin, policy=policy)
    else:
        with open(args.message) as file:
            return email.message_from_file(file, policy=policy)

def scan_mail_files(mail_dir):
    """Walk mail_dir recursively, yielding paths to files in cur/ and new/ subdirs."""
    for root, dirs, files in os.walk(mail_dir):
        basename = os.path.basename(root)
        if basename not in ('cur', 'new'):
            continue
        for name in files:
            yield os.path.join(root, name)

def parse_message_ids(value):
    if not value:
        return []
    return re.findall(r'<([^>]+)>', value)

def index_message(msg, path, by_msgid, subj_map, refs_map, children):
    msgid = msg.get('Message-Id', '')
    msgid = re.sub(r'[<>]', '', msgid).strip()
    if not msgid:
        return

    by_msgid[msgid] = path
    subj_map[msgid] = msg.get('Subject', '')

    related = set()
    for ref in parse_message_ids(msg.get('References', '')):
        related.add(ref)
    for ref in parse_message_ids(msg.get('In-Reply-To', '')):
        related.add(ref)

    refs_map[msgid] = related
    for ref in related:
        children.setdefault(ref, set()).add(msgid)

def recursive_copy(message_id, mail_dir, dest_dir, seed_msg=None):
    """Find all emails belonging to the same thread as message_id and copy them to dest_dir.
    seed_msg is the original piped-in message (may not be in the maildir yet).
    Returns (copied_count, root_subject) or (0, None) if nothing found."""

    by_msgid = {}   # msgid -> filepath
    subj_map = {}   # msgid -> subject
    refs_map = {}   # msgid -> set of related msgids
    children = {}   # msgid -> set of msgids that reference it

    policy = email.policy.EmailPolicy(utf8=True)

    # Index the piped-in message so BFS has edges even if it's not in maildir
    if seed_msg:
        index_message(seed_msg, None, by_msgid, subj_map, refs_map, children)

    for path in scan_mail_files(mail_dir):
        try:
            with open(path) as f:
                msg = email.message_from_file(f, policy=policy)
        except Exception:
            continue

        index_message(msg, path, by_msgid, subj_map, refs_map, children)

    # BFS to find all thread members
    thread = set()
    queue = [message_id]
    while queue:
        mid = queue.pop()
        if mid in thread:
            continue
        thread.add(mid)
        for ref in refs_map.get(mid, set()):
            queue.append(ref)
        for child in children.get(mid, set()):
            queue.append(child)

    # Find root message (no In-Reply-To / References in the thread)
    root_mid = None
    root_subj = None
    for mid in thread:
        if mid in by_msgid and not refs_map.get(mid):
            root_mid = mid
            root_subj = subj_map.get(mid)
            break
    if root_subj is None:
        root_mid = message_id
        root_subj = subj_map.get(message_id, '')

    # Copy matching files, renamed to sanitized subject
    os.makedirs(dest_dir, exist_ok=True)

    copied = 0
    used_names = set()
    for mid in thread:
        if mid not in by_msgid or by_msgid[mid] is None:
            continue
        src = by_msgid[mid]
        name = '00_root' if mid == root_mid else sanitize_subj(subj_map[mid])
        base = name
        seq = 2
        while name in used_names:
            name = f'{base}_{seq}'
            seq += 1
        used_names.add(name)
        dst = os.path.join(dest_dir, name)
        shutil.copy2(src, dst)
        copied += 1

    print(f'copied {copied} messages to {dest_dir}')
    return copied, root_subj

def find_by_message_id(mail_dir, message_id):
    """Find the file in maildir matching the given message-id."""
    policy = email.policy.EmailPolicy(utf8=True)
    for path in scan_mail_files(mail_dir):
        try:
            with open(path) as f:
                msg = email.message_from_file(f, policy=policy)
        except Exception:
            continue
        msgid = re.sub(r'[<>]', '', msg.get('Message-Id', '')).strip()
        if msgid == message_id:
            return msg
    return None

def cmd_begin(args):
    mail_dir = args.mail

    if args.message == '-':
        seed_msg = get_msg(args)
    elif os.path.exists(args.message):
        seed_msg = get_msg(args)
    else:
        # Treat -m value as a message-id
        mid = re.sub(r'[<>]', '', args.message)
        seed_msg = find_by_message_id(mail_dir, mid)
        if not seed_msg:
            print(f'message-id {mid} not found in {mail_dir}')
            return

    message_id = re.sub(r'[<>]', '', seed_msg['Message-Id'])

    review_dir = args.review
    tmp_dir = os.path.join(review_dir, 'tmp')

    if os.path.exists(tmp_dir):
        print(f'directory {tmp_dir} already exists, bailing out...')
        return

    copied, root_subj = recursive_copy(message_id, mail_dir, tmp_dir, seed_msg=seed_msg)
    if copied == 0:
        print(f'no messages found for {message_id}')
        shutil.rmtree(tmp_dir)
        return

    final_name = sanitize_subj(root_subj)
    final_dir = os.path.join(review_dir, final_name)
    if os.path.exists(final_dir):
        shutil.rmtree(tmp_dir)
        print(f'review directory {final_dir} already exists')
        return

    shutil.move(tmp_dir, final_dir)
    create_reply_templates(final_dir, args.me)
    print(f'created review in {final_dir}')

    if args.tmux:
        subprocess.check_call(['tmux', 'new-window', '-n', final_name, '-c', final_dir])

def cmd_reply(args):
    reply_dir = os.path.join('.', 'reply')
    ref_dir = os.path.join('.', 'ref')

    if not os.path.exists(reply_dir) or not os.path.exists(ref_dir):
        print('should be called from a review directory with reply/ and ref/')
        return

    differ = []

    for name in os.listdir(reply_dir):
        reply_path = os.path.join(reply_dir, name)
        ref_path = os.path.join(ref_dir, name)
        if not os.path.isfile(reply_path):
            continue
        if not os.path.exists(ref_path) or not filecmp.cmp(reply_path, ref_path):
            differ.append(reply_path)

    if len(differ) == 0:
        print('no modified replies to send')
        return

    print('will send the following replies:')
    for file in differ:
        print(f'- {file}')

    while True:
        response = input('continue? (y/n): ')
        if response.lower() == 'n':
            return
        elif response.lower() == 'y':
            break

    for file in differ:
        if args.dry_run:
            print(f"DRY: cat {file} | msmtp -t")
            continue

        with subprocess.Popen(['msmtp', '-t'], stdin=subprocess.PIPE) as p:
            with open(file) as f:
                p.communicate(f.read().encode("utf-8"))

def sync_prompts(prompts_dir):
    if not os.path.isdir(prompts_dir):
        subprocess.check_call(['git', 'clone',
            'https://github.com/masoncl/review-prompts',
            prompts_dir])
    else:
        subprocess.check_call(['git', 'pull'], cwd=prompts_dir)

def build_ai_prompt(args):
    sync_prompts(args.prompts)

    reply_dir = os.path.join('.', 'reply')
    if not os.path.isdir(reply_dir):
        print('should be called from a review directory with reply/')
        return None

    files = sorted(f for f in os.listdir(reply_dir)
                   if os.path.isfile(os.path.join(reply_dir, f)))

    if not files:
        print('no reply templates found in reply/')
        return None

    # Detect if I'm the author
    policy = email.policy.EmailPolicy(utf8=True)
    root_path = os.path.join('.', '00_root')
    with open(root_path) as f:
        root_msg = email.message_from_file(f, policy=policy)
    i_am_author = args.me in (root_msg['From'] or '')

    feedback = '\n'.join(f'- {os.path.abspath(os.path.join(reply_dir, f))}' for f in files)

    # List original patch files (from the root author, in the review dir root)
    author = root_msg['From']
    patches = []
    for name in sorted(os.listdir('.')):
        path = os.path.join('.', name)
        if not os.path.isfile(path):
            continue
        try:
            with open(path) as f:
                msg = email.message_from_file(f, policy=policy)
            if msg.get('From') == author:
                patches.append(os.path.abspath(path))
        except Exception:
            continue
    original_patches = '\n'.join(f'- {p}' for p in patches)

    if i_am_author:
        try:
            unpushed = subprocess.check_output(
                ['git', 'log', '--format=%h', '@{u}..HEAD'],
                cwd=args.linux, stderr=subprocess.DEVNULL
            ).decode().strip()
        except subprocess.CalledProcessError:
            unpushed = ''

        unpushed = '\n'.join(f'- {c}' for c in unpushed.splitlines() if c)
        return f"""Using the prompt {args.prompts}/kernel/review-core.md and the review prompt directory {args.prompts}/kernel, address the feedback for the following commits:
{unpushed}

The feedback is in the following files:
{feedback}

Each feedback file is an email template for the reply.
Add inline comments that explain why each particular comment is valid or not.
If there is already an inline comment, make sure it's correct and update if needed.
Do not use any indentation for these inline comments, but leave an empty line above and below.
If the feedback is valid, add new commit to address the feedback so I can squash that commit later (unless there is already a fix for that). Mark these commits as 'fixup!'.
The subject of each feedback email file references the respective commit, so it should be easy to pair commits to feedback files.

Create a sub-agent to review each feedback file in parallel.
"""
    else:
        return f"""Using the prompt {args.prompts}/kernel/review-core.md and the review prompt directory {args.prompts}/kernel, address the feedback for the following patches:
{original_patches}

The write feedback to the following files:
{feedback}

Each feedback file is an email template for the reply.
Add inline comments if you think there are some problems in the patches.
If there is already an inline comment, make sure it's correct and update if needed.
Do not use any indentation for these inline comments, but leave an empty line above and below.
The subject of each feedback email file references the respective patch, so it should be easy to pair commits to feedback files.

Create a sub-agent to review each feedback file in parallel.

Note that you don't have to treat every feedback item as something that needs to be addressed.
Feel free to push back on the following suggestions:
- holding some locks (rtnl) for too long
- races with work stealing where work will be empty
- corner cases that are very hard or impossible to hit
"""

def run_harness(harness, prompt, linux_dir):
    import shlex
    cmd = shlex.split(harness) + [prompt]
    os.chdir(linux_dir)
    return subprocess.call(cmd)

def cmd_feedback(args):
    prompt = build_ai_prompt(args)
    if not prompt:
        return
    os.chdir(args.linux)
    import shlex
    cmd = shlex.split(args.harness) + [prompt]
    os.execvp(cmd[0], cmd)

def cmd_turbo_feedback(args):
    prompt = build_ai_prompt(args)
    if not prompt:
        return
    for harness in args.harnesses:
        print(f'--- running: {harness} ---')
        run_harness(harness, prompt, args.linux)

def build_branch_prompt(args):
    sync_prompts(args.prompts)

    try:
        unpushed = subprocess.check_output(
            ['git', 'log', '--format=%h', '@{u}..HEAD'],
            stderr=subprocess.DEVNULL
        ).decode().strip()
    except subprocess.CalledProcessError:
        unpushed = ''

    if args.prompt:
        prompt_text = args.prompt
    else:
        commits = ' '.join(unpushed.splitlines())
        prompt_text = f'review all unpushed commits: {commits}'

    return f'Using the prompt {args.prompts}/kernel/review-core.md and the review prompt directory {args.prompts}/kernel, {prompt_text}'

def cmd_branch(args):
    prompt = build_branch_prompt(args)
    import shlex
    cmd = shlex.split(args.harness) + [prompt]
    os.execvp(cmd[0], cmd)

def cmd_turbo_branch(args):
    prompt = build_branch_prompt(args)
    for harness in args.harnesses:
        print(f'--- running: {harness} ---')
        run_harness(harness, prompt, os.getcwd())

parser = argparse.ArgumentParser(description="krn-review")
parser.add_argument('--review', type=str, default=DIR_REVIEW)
parser.add_argument('--mail', type=str, default=os.path.expanduser(DIR_MAIL))
parser.add_argument('--me', type=str, default=ME)
parser.add_argument('--harnesses', type=str, nargs='+', default=HARNESSES)

subparsers = parser.add_subparsers(dest="command", required=True)

begin = subparsers.add_parser("begin")
begin.add_argument('-m', '--message', type=str, default='-')
begin.add_argument('--tmux', action='store_true')
begin.set_defaults(func=cmd_begin)

feedback = subparsers.add_parser("feedback")
feedback.add_argument('--prompts', type=str, default=DIR_PROMPTS)
feedback.add_argument('--linux', type=str, default=DIR_LINUX)
feedback.add_argument('--harness', type=str, default=HARNESSES[0])
feedback.set_defaults(func=cmd_feedback)

turbo_feedback = subparsers.add_parser("turbo-feedback")
turbo_feedback.add_argument('--prompts', type=str, default=DIR_PROMPTS)
turbo_feedback.add_argument('--linux', type=str, default=DIR_LINUX)
turbo_feedback.set_defaults(func=cmd_turbo_feedback)

branch = subparsers.add_parser("branch")
branch.add_argument('-p', '--prompt', type=str)
branch.add_argument('--prompts', type=str, default=DIR_PROMPTS)
branch.add_argument('--harness', type=str, default=HARNESSES[0])
branch.set_defaults(func=cmd_branch)

turbo_branch = subparsers.add_parser("turbo-branch")
turbo_branch.add_argument('-p', '--prompt', type=str)
turbo_branch.add_argument('--prompts', type=str, default=DIR_PROMPTS)
turbo_branch.set_defaults(func=cmd_turbo_branch)

reply = subparsers.add_parser("reply")
reply.add_argument('--dry-run', action='store_true')
reply.set_defaults(func=cmd_reply)

args = parser.parse_args()
args.func(args)
