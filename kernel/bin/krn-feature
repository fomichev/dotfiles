#!/bin/bash

set -e

MYDIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}" )" &>/dev/null && pwd)

FEATURE_NAME="$1"
FEATURE_BRANCH="${2:-net-next}"

if [ -z "$FEATURE_NAME" ]; then
	echo "Usage: krn-feature <feature-name> [branch] [feature-plan.md]"
	echo "  branch defaults to net-next"
	exit 1
fi

LINUX_SRC=~/src/linux
WORKTREE=${LINUX_SRC}-${FEATURE_NAME}
BRANCH="upstream/${FEATURE_BRANCH}/${FEATURE_NAME}/1"
PLAN_PATH=$HOME/tasks/${FEATURE_NAME}.md

if [ ! -d "$WORKTREE" ]; then
	cd "$LINUX_SRC"
	git worktree add -b "$BRANCH" "$WORKTREE" "upstream/${FEATURE_BRANCH}/main"
fi

cd "$WORKTREE"

PROMPT="Build the kernel using /kernel-build-qemu skill, then run selftests using /kernel-selftest-qemu skill to establish a baseline."

if [ -e "$PLAN_PATH" ]; then
	PROMPT="$PROMPT Then read the plan from $PLAN_PATH, show me a summary, and ask whether I want to proceed with it."
else
	PROMPT="$PROMPT Then ask me what I'd like to work on."
fi

krn-claude "$PROMPT"
