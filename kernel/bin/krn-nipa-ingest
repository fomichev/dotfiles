#!/bin/bash

MYDIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}" )" &>/dev/null && pwd)
source $MYDIR/../host_lib.sh

VENV=~/nipa-venv
NIPA=~/src/nipa

if [[ ! -d $NIPA ]]; then
	pushd $(dirname $NIPA)
	git clone https://github.com/linux-netdev/nipa.git
	popd
fi

if [[ ! -d $VENV ]]; then
	python3 -m venv $VENV
	$VENV/bin/pip install -r ~/src/dotfiles/kernel/requirements.txt
fi

source $VENV/bin/activate

TMPDIR=$HOME/tmp/nipa-ingest
BRANCH="$(get_branch)"

cleanup() {
	cd $KDIR
	git checkout $BRANCH
	rm -rf $TMPDIR
}
trap cleanup EXIT

cd $KDIR

krn-mrproper
krn-format-patch -n

if [[ "$(ls *.patch)" = "*.patch" ]]; then
	echo "no patches found, everything is committed?"
	exit 1
fi

rm -rf $TMPDIR
mkdir -p $TMPDIR
mv *.patch $TMPDIR
git checkout upstream/net-next/main # -b test

#NO_BUILD+="--disable-test"
#NO_BUILD+=" patch/build_32bit"
#NO_BUILD+=" patch/build_clang_rust"
#NO_BUILD+=" patch/build_allmodconfig_warn"
#NO_BUILD+=" patch/build_clang"

cd $NIPA
./ingest_mdir.py --tree-name net-next --mdir $TMPDIR --tree $KDIR $NO_BUILD
