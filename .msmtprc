defaults
auth           on
tls            on
# msmtp-proxy
# {{{
tls_trust_file /etc/ssl/certs/ca-bundle.crt
# ---
#tls_trust_file /etc/ssl/certs/ca-certificates.crt
# }}}
logfile        ~/.msmtp.log

# Gmail
account        gmail
# msmtp-proxy
# {{{
host 127.0.0.1
port 13776
tls_certcheck off
# ---
#host           smtp.gmail.com
#port           465
# }}}
tls_starttls   off
from           sdf.kernel@gmail.com
user           sdf.kernel
passwordeval   /home/sdf/bin/secret gmail-sdf.kernel

# Set a default account
account default: gmail
